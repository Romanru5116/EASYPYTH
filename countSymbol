из входной строки считаем маасимальное число символов
from collections import Counter
# Читаем строку от пользователя
s = input().lower()

# Считаем количество вхождений каждого символа
counts =  Counter(s)
    
# Находим максимальное значение среди всех подсчетов
max_val = max(counts.values())

print(max_val)
