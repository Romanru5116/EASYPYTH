#Ваша задача — определить, сколько символов в данной строке являются цифрами, и также найти сумму всех этих цифр. Вывести количество и сумму
a = input()  # зачитали
s = 0        # Сумма цифр
c = 0        # Количество цифр

for i in a:
    if i.isdigit():      # символ цифра?
        s += int(i)      # символ в число для сложения
        c += 1           # инкремент счетчик
        
print(c, s)
